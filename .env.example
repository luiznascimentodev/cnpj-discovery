# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cnpj
POSTGRES_USER=cnpj_user
POSTGRES_PASSWORD=changeme

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# ETL Configuration
ETL_DATA_DIR=/tmp/cnpj_data
ETL_BATCH_SIZE=500000
ETL_WORKERS=4
ETL_DOWNLOAD_WORKERS=2
ETL_PROCESS_WORKERS=6
ETL_INDEX_WORKERS=4
ETL_ACTIVE_ONLY=true
ETL_AUTO_LOAD_PUBLIC_DATA=false
ETL_MIN_FREE_GB=70
ETL_KEEP_ZIPS_AFTER_LOAD=false

# Notificações (opcional)
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# Receita Federal - WebDAV Configuration
RF_SHARE_TOKEN=gn672Ad4CF8N6TK
RF_WEBDAV_BASE=https://arquivos.receitafederal.gov.br/public.php/webdav/
RF_HTTP_INDEX_URL=https://arquivos.receitafederal.gov.br/dados/cnpj/dados_abertos_cnpj/
